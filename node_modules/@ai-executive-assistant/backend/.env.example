NODE_ENV=development
PORT=4000
# For split deployments, comma-separate allowed frontend origins.
# For one-service hosting, set this to your public app URL.
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_executive_assistant
JWT_SECRET=replace-with-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-32-character-secret!!
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
