{
  "name": "ai-executive-assistant",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w backend && npm run build -w frontend",
    "start": "npm run start -w backend",
    "migrate": "npm run migrate -w backend",
    "migrate:prod": "npm run migrate:prod -w backend",
    "android:sync": "npm run android:sync -w frontend",
    "android:open": "npm run android:open -w frontend",
    "ota:init": "npm run ota:init -w frontend",
    "ota:upload": "npm run ota:upload -w frontend"
  }
}
