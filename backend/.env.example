NODE_ENV=development
PORT=4000
# For split deployments, comma-separate allowed frontend origins.
# For one-service hosting, set this to your public app URL.
FRONTEND_URL=http://localhost:5173
# Optional extra allowed origins. Keep these for Capacitor APK builds.
CORS_ORIGINS=https://localhost,http://localhost,capacitor://localhost,ionic://localhost
MOBILE_APP_URL=oconnect://app
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_executive_assistant
JWT_SECRET=replace-with-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-32-character-secret!!
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:4000/api/auth/zoho/callback
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_MAIL_API_URL=https://mail.zoho.com
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4000/api/auth/social/facebook/callback
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/auth/social/instagram/callback
# business = Instagram API with Instagram Login, basic = older Basic Display flow
INSTAGRAM_OAUTH_MODE=business
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4000/api/auth/social/linkedin/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:4000/api/auth/social/x/callback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:4000/api/auth/social/reddit/callback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
