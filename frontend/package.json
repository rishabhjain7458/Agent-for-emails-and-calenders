{
  "name": "@ai-executive-assistant/frontend",
  "version": "1.0.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:mobile": "tsc && vite build --mode mobile",
    "android:sync": "npm run build:mobile && cap sync android",
    "android:open": "cap open android",
    "ota:init": "npx @capgo/cli@latest init",
    "ota:upload": "npm run build:mobile && npx @capgo/cli@latest bundle upload com.oconnect.assistant --path ./dist --channel production --package-json ./package.json --node-modules ../node_modules",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.0",
    "@capgo/capacitor-speech-recognition": "^8.1.7",
    "@capgo/capacitor-updater": "^8.50.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/react": "^6.1.15",
    "@fullcalendar/timegrid": "^6.1.15",
    "@mui/icons-material": "^6.3.1",
    "@mui/material": "^6.3.1",
    "axios": "^1.7.9",
    "capacitor-secure-storage-plugin": "^0.13.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
